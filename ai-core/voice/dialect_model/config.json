{
  "_meta": {
    "file"        : "ai-core/voice/dialect_model/config.json",
    "purpose"     : "Runtime configuration for the Egyptian-Arabic voice & dialect pipeline — CommandParser, ConfidenceScorer, AmbiguityHandler, SentimentAnalyzer, Whisper STT",
    "project"     : "RIVA Health Platform v3.0",
    "author"      : "Goda Emad (AI Core)",
    "version"     : "2.2.0",
    "updated"     : "2026-03-18",
    "environment" : "offline-first — all values must allow the system to run with ZERO network access",
    "note"        : "Keys prefixed with _ are documentation-only and are ignored by the loader"
  },

  "command_parser": {
    "_note"                        : "Controls CommandParser behaviour — feeds into confidence_scorer and ambiguity_handler",
    "min_confidence"               : 0.35,
    "negation_window_tokens"       : 4,
    "max_symptoms_for_full_score"  : 3,
    "dialect"                      : "ar-EG",
    "normalise_diacritics"         : true,
    "longest_match_first"          : true,
    "batch_max_size"               : 32
  },

  "confidence_scorer": {
    "_note"    : "Weights must sum to exactly 1.0 — validated at startup",
    "weights": {
      "intent_confidence" : 0.45,
      "symptom_evidence"  : 0.25,
      "duration_bonus"    : 0.10,
      "urgency_adjustment": 0.10,
      "ambiguity_penalty" : 0.10
    },
    "thresholds": {
      "_note"       : "Used for routing decisions — act / clarify / fallback / unrecognised",
      "act"         : 0.70,
      "clarify"     : 0.45,
      "fallback"    : 0.30
    },
    "min_score"                    : 0.10,
    "max_symptoms_for_full_score"  : 3,
    "urgency_adjustments": {
      "emergency" :  1.00,
      "high"      :  0.70,
      "medium"    :  0.30,
      "low"       : -0.20
    }
  },

  "ambiguity_handler": {
    "_note"                         : "AmbiguityHandler thresholds and clarification policy",
    "min_confidence_for_no_check"   : 0.75,
    "max_clarification_questions"   : 2,
    "severe_ambiguity_threshold"    : 0.25,
    "conflicting_symptoms_as_severe": true,
    "missing_body_part_penalty"     : 0.08,
    "missing_duration_penalty"      : 0.05
  },

  "sentiment_analyzer": {
    "_note"             : "Lightweight rule-based sentiment for Egyptian Arabic — no external model",
    "distress_threshold": -0.50,
    "calm_threshold"    :  0.50,
    "emergency_override": true,
    "_emergency_override_note": "If intent=EMERGENCY, sentiment is forced to -1.0 regardless of lexicon score"
  },

  "whisper": {
    "_note"            : "Whisper STT — offline INT8 ONNX model",
    "model_path"       : "ai-core/voice/dialect_model/whisper_int8.onnx",
    "language"         : "ar",
    "task"             : "transcribe",
    "beam_size"        : 3,
    "best_of"          : 3,
    "temperature"      : 0.0,
    "compression_ratio_threshold": 2.4,
    "logprob_threshold"          : -1.0,
    "no_speech_threshold"        : 0.6,
    "max_audio_duration_seconds" : 30,
    "sample_rate_hz"             : 16000,
    "chunk_length_seconds"       : 10,
    "vad_filter"                 : true,
    "vad_min_speech_duration_ms" : 250,
    "vad_min_silence_duration_ms": 500
  },

  "text_to_speech": {
    "_note"      : "Offline TTS — Egyptian Arabic responses back to the user",
    "engine"     : "pyttsx3",
    "language"   : "ar",
    "rate_wpm"   : 145,
    "volume"     : 0.90,
    "pitch"      : 1.0,
    "fallback"   : "browser_speech_synthesis"
  },

  "routing": {
    "_note": "Maps TargetModel enum values to FastAPI route prefixes",
    "triage_engine"         : "/api/triage",
    "pregnancy_risk"        : "/api/pregnancy",
    "school_health"         : "/api/school",
    "readmission_predictor" : "/api/readmission",
    "los_predictor"         : "/api/los",
    "medical_chatbot"       : "/api/chat",
    "navigation_handler"    : "/api/navigate",
    "system_handler"        : "/api/system"
  },

  "urgency_escalation": {
    "_note"                    : "What happens when urgency=EMERGENCY regardless of confidence",
    "skip_clarification"       : true,
    "force_route_to_triage"    : true,
    "alert_doctor_dashboard"   : true,
    "log_level"                : "CRITICAL",
    "response_max_latency_ms"  : 800
  },

  "offline": {
    "_note"                       : "Governs offline-mode behaviour — all models must work without network",
    "enabled"                     : true,
    "cache_parsed_commands"       : true,
    "cache_ttl_seconds"           : 300,
    "sync_on_reconnect"           : true,
    "background_sync_interval_s"  : 60,
    "max_cached_commands"         : 200,
    "storage_key_prefix"          : "riva_voice_"
  },

  "security": {
    "_note"                  : "Security settings for the voice pipeline",
    "encrypt_transcriptions" : true,
    "encryption_algorithm"   : "AES-256-GCM",
    "sign_parsed_commands"   : true,
    "pii_scrub_before_log"   : true,
    "pii_patterns"           : [
      "\\d{14}",
      "01[0-2,5]{1}[0-9]{8}",
      "\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Z|a-z]{2,}\\b"
    ],
    "_pii_note"              : "Patterns: Egyptian national ID (14 digits), mobile number, email"
  },

  "logging": {
    "level"              : "INFO",
    "log_parse_time_ms"  : true,
    "log_score_breakdown": false,
    "_log_score_note"    : "Set to true in development to see full ScoreBreakdown per command",
    "log_negated_symptoms": true,
    "max_text_length_in_log": 120
  },

  "performance": {
    "_note"                        : "Latency targets — enforced via middleware alerts",
    "target_parse_latency_ms"      : 50,
    "target_whisper_latency_ms"    : 1500,
    "target_end_to_end_latency_ms" : 2000,
    "warm_up_on_startup"           : true,
    "warm_up_text"                 : "عندي ألم في صدري بقالي يومين"
  }
}
